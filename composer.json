{
    "name": "scandiweb/fullstack",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "psr-0": {
            "": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@composer dump-autoload -o"
        ],
        "post-update-cmd": [
            "@composer dump-autoload -o"
        ]
    },
    "require": {
        "nikic/fast-route": "^1.3",
        "webonyx/graphql-php": "^15.2",
        "vlucas/phpdotenv": "^5.6"
    }
}
